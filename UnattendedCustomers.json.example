{
    "_reference": {
        "HuduCompanySlug": "12-character hex slug from the Hudu company URL — https://hudu.example.com/c/<slug>",
        "HuduComanyName": "(optional) Exact company name as it appears in Hudu — only used for easier readability in this file, not used by the script",
        "Modules": {
            "1": "Microsoft Entra Audit    — Identity, MFA, roles, Conditional Access",
            "2": "Exchange Online Audit    — Mailboxes, permissions, mail flow",
            "3": "SharePoint Online Audit  — Sites, permissions, storage, OneDrive",
            "4": "Mail Security Audit      — DKIM, DMARC, SPF, anti-spam/phish policies",
            "5": "Intune / Endpoint Audit  — Devices, compliance, configuration, apps, enrollment",
            "9": "Run All                  — Modules 1, 2, 3, 4, 5 + summary"
        }
    },
    "customers": [
        {
            "HuduCompanySlug": "a1b2c3d4e5f6",
            "HuduComanyName": "Contoso Ltd",
            "Modules": [ 9 ]
        },
        {
            "HuduCompanySlug": "f6e5d4c3b2a1",
            "HuduComanyName": "Fabrikam Inc",
            "Modules": [ 1, 2, 5 ]
        }
    ]
}

# UnattendedCustomers.psd1
# Copy this file to UnattendedCustomers.psd1 and add your customers.
# UnattendedCustomers.psd1 is excluded from git to keep customer slugs private.
#
# HuduCompanySlug : 12-character hex slug from the Hudu company URL
#                   e.g. https://hudu.example.com/c/<slug>
#
# HuduCompanyName : (optional) Human-readable label — not used by the script,
#                   just makes this file easier to read.
#
# Modules         : Which audit modules to run for this customer.
#                   1 = Microsoft Entra    — Identity, MFA, roles, Conditional Access
#                   2 = Exchange Online    — Mailboxes, permissions, mail flow
#                   3 = SharePoint Online  — Sites, permissions, storage, OneDrive
#                   4 = Mail Security      — DKIM, DMARC, SPF, anti-spam/phish policies
#                   5 = Intune / Endpoint  — Devices, compliance, configuration, apps
#                   6 = Teams              — Federation, client config, meeting/app policies
#                   7 = Maester            — M365 Security Baseline (CISA SCuBA, CIS v5.0, EIDSCA)
#                   A = Run All            — Modules 1–7 + summary

@{
    Customers = @(
        @{
            HuduCompanySlug = 'a1b2c3d4e5f6'
            HuduCompanyName = 'Contoso Ltd'
            Modules         = @('A')
        }
        @{
            HuduCompanySlug = 'f6e5d4c3b2a1'
            HuduCompanyName = 'Fabrikam Inc'
            Modules         = @(1, 2, 5)
        }
    )
}

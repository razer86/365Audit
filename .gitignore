# ── Certificates & Secrets ────────────────────
# Private key files — never commit
*.pfx
*.p12

# ── Local Configuration ──────────────────────
# Contains Hudu API key, tenant info, etc.
config.psd1
# Contains Hudu company slugs for batch runs
UnattendedCustomers.psd1

# ── Audit Output & Reports ───────────────────
*.html
*.pdf
*.log

# ── Resource Files (auto-downloaded) ─────────
*.csv

# ── Documents ────────────────────────────────
*.docx
*.dotx

# ── Data Files ───────────────────────────────
*.json
# version.json is tracked — override the blanket ignore
!version.json

# ── Scripts & Scratch ────────────────────────
*.py
Test-*
